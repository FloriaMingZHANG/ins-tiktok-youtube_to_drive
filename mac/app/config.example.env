# 复制为 .env 后填写
# Google 表格 URL（或仅填写 SPREADSHEET_KEY）
SPREADSHEET_URL=https://docs.google.com/spreadsheets/d/你的表格ID/edit

# 可选：直接填表格 ID（从 URL 的 /d/xxx/ 中取）
# SPREADSHEET_KEY=你的表格ID

# 工作表名称（左下角标签名，默认第一个表可留空）
SHEET_NAME=

# 链接列（支持 Instagram / TikTok / YouTube / YouTube Shorts / 小红书 等）
URL_COLUMN=A
# 文件名列
NAME_COLUMN=B

# 数据从第几行开始（表头行数，无表头填 0）
HEADER_ROWS=1

# 可选：上传后把视频 Drive 链接写回表格的列（如 C），留空则不写回
# RESULT_COLUMN=C

# 可选：封面图 Drive 链接写回表格的列（如 D）；留空则不下载/不写回封面
# THUMBNAIL_COLUMN=D
# 为 1 时：不把封面上传 Drive、不写 Sheet 封面列，只把封面原图保存到 FEISHU_EXPORT_DIR/covers/，方便你复制到飞书
# SKIP_DRIVE_COVER=1
# 本次运行做哪一类：DO_VIDEO=1 下载并上传视频；DO_COVER=1 下载封面并导出。可只开一个（设为 0 关闭）
# DO_VIDEO=1
# DO_COVER=1

# 可选：飞书多维表格 - 把封面图片作为「文件」上传到对应记录（列类型须为「文件」）
# 在飞书开放平台创建应用并开通「多维表格」权限，获取 app_id、app_secret
# app_token 从多维表格 URL 取（如 https://xxx.feishu.cn/base/AppToken?table=TableId），table_id 为数据表 ID
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_APP_TOKEN=
# FEISHU_TABLE_ID=
# FEISHU_MATCH_FIELD=文件名
# FEISHU_FILE_FIELD=封面
# 可选：导出目录。设置后 main.py 会把封面原图 + links.csv 导出到此目录，再用 push_export_to_feishu.py 推送到飞书
# FEISHU_EXPORT_DIR=feishu_export

# 可选：Google Drive 上传到的文件夹 ID（Drive 链接中 /folders/xxx 的 xxx）
# 留空则上传到「我的云端硬盘」根目录
DRIVE_FOLDER_ID=

# 可选：Instagram / X (Twitter) / TikTok 等需登录时使用。二选一即可。
# 方式一：从浏览器读取登录状态（运行时会提示在浏览器登录后选 Chrome/Firefox/Edge）
# 注意：Chrome/Edge 打开时无法读取 cookie，需完全关闭浏览器再运行；推荐 Firefox 可保持打开
# COOKIES_FROM_BROWSER=firefox
# 方式二：使用导出的 Netscape 格式 cookies 文件
# COOKIES_FILE=cookies.txt

# 网速慢时：设为 1 自动延长超时和间隔（连接 120s、单条最长 15 分钟、每条间隔 10s、重试 8 次）
# SLOW_NETWORK=1
# 也可单独设置：SOCKET_TIMEOUT=120 DOWNLOAD_TIMEOUT=900 DOWNLOAD_DELAY_SECONDS=10 DOWNLOAD_RETRIES=8
# 大文件上传 Drive 仍报 timed out 时加大（秒）：默认慢网 1200、否则 600
# DRIVE_HTTP_TIMEOUT=1800

# 可选：服务账号 JSON 路径，默认当前目录 credentials.json
# CREDENTIALS_PATH=credentials.json
